generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadScore {
  Hot
  Warm
  LowFit
}

enum LeadStatus {
  New
  Contacted
  Qualified
  AppointmentBooked
  EstimateCompleted
  NoShow
  Won
  Lost
  ReplacementNeeded
}

enum AppointmentStatus {
  Booked
  Confirmed
  Rescheduled
  Cancelled
  Showed
  NoShow
  Won
  Lost
}

enum MessageChannel {
  Email
  SMS
}

enum MessageDirection {
  Outbound
  Inbound
}

model Contractor {
  id           String        @id @default(cuid())
  name         String
  companyName  String
  email        String        @unique
  phone        String?
  calendlyUrl  String?
  createdAt    DateTime      @default(now())
  leads        Lead[]
  appointments Appointment[]
  campaigns    Campaign[]
  serviceAreas ServiceArea[]
}

model Lead {
  id                     String       @id @default(cuid())
  contractorId           String?
  contractor             Contractor?  @relation(fields: [contractorId], references: [id])
  name                   String
  phone                  String
  email                  String       @unique
  zipCode                String
  projectType            String
  propertyType           String
  squareFootage          Int?
  budget                 Int
  timeline               String
  preferredContactMethod String
  notes                  String?
  leadScore              LeadScore
  status                 LeadStatus   @default(New)
  ownsProperty           Boolean      @default(true)
  createdAt              DateTime     @default(now())
  estimateAmount         Int?
  jobValue               Int?
  closeDate              DateTime?
  salesNotes             String?
  assignedContractor     String?
  revenueGenerated       Int?
  appointments           Appointment[]
  messageLogs            MessageLog[]
}

model Appointment {
  id                 String            @id @default(cuid())
  leadId             String
  lead               Lead              @relation(fields: [leadId], references: [id])
  contractorId       String
  contractor         Contractor        @relation(fields: [contractorId], references: [id])
  provider           String            @default("cal.com")
  externalBookingId  String            @unique
  eventTypeId        String?
  scheduledAt        DateTime
  endsAt             DateTime?
  timezone           String
  locationType       String?
  meetingLocation    String?
  status             AppointmentStatus @default(Booked)
  cancellationReason String?
  rescheduleUrl      String?
  cancellationUrl    String?
  replacementNeeded  Boolean           @default(false)
  reminder24hSentAt  DateTime?
  reminder2hSentAt   DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([leadId])
  @@index([contractorId])
  @@index([scheduledAt])
}

model MessageLog {
  id        String           @id @default(cuid())
  leadId    String?
  lead      Lead?            @relation(fields: [leadId], references: [id])
  channel   MessageChannel
  direction MessageDirection @default(Outbound)
  recipient String
  subject   String?
  body      String
  status    String           @default("mocked")
  createdAt DateTime         @default(now())
}

model Campaign {
  id           String     @id @default(cuid())
  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id])
  name         String
  source       String
  budget       Int?
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now())
}

model ServiceArea {
  id           String     @id @default(cuid())
  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id])
  zipCode      String
  city         String?
  active       Boolean    @default(true)

  @@unique([contractorId, zipCode])
}
